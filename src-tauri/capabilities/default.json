{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the app windows",
  "windows": ["main", "panel", "toast"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "opener:default",
    "opener:allow-open-path",
    "notification:default",
    "notification:allow-register-action-types",
    "updater:default",
    "process:default",
    { "identifier": "fs:allow-read-text-file", "allow": [{ "path": "$APPCONFIG" }, { "path": "$APPCONFIG/*" }, { "path": "$APPCONFIG/**" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "$APPCONFIG" }, { "path": "$APPCONFIG/*" }, { "path": "$APPCONFIG/**" }] },
    { "identifier": "fs:allow-read-dir", "allow": [{ "path": "$APPCONFIG" }, { "path": "$APPCONFIG/*" }, { "path": "$APPCONFIG/**" }] },
    { "identifier": "fs:allow-mkdir", "allow": [{ "path": "$APPCONFIG" }, { "path": "$APPCONFIG/*" }, { "path": "$APPCONFIG/**" }] },
    { "identifier": "fs:allow-remove", "allow": [{ "path": "$APPCONFIG/*" }, { "path": "$APPCONFIG/**" }] },
    { "identifier": "fs:allow-exists", "allow": [{ "path": "$APPCONFIG" }, { "path": "$APPCONFIG/*" }, { "path": "$APPCONFIG/**" }] },
    { "identifier": "fs:allow-watch", "allow": [{ "path": "$APPCONFIG" }, { "path": "$APPCONFIG/*" }, { "path": "$APPCONFIG/**" }] },
    { "identifier": "fs:allow-unwatch", "allow": [{ "path": "$APPCONFIG" }, { "path": "$APPCONFIG/*" }, { "path": "$APPCONFIG/**" }] }
  ]
}
