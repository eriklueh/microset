{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "microset",
  "version": "0.1.0",
  "identifier": "com.microset.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "microset",
        "width": 940,
        "height": 680,
        "minWidth": 600,
        "minHeight": 460,
        "resizable": true,
        "center": true,
        "transparent": true
      },
      {
        "label": "panel",
        "title": "microset",
        "width": 272,
        "height": 136,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
