{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "microset",
  "version": "0.1.0",
  "identifier": "com.microset.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "microset",
        "width": 1080,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "decorations": false
      },
      {
        "label": "panel",
        "title": "microset",
        "width": 272,
        "height": 136,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "toast",
        "title": "microset",
        "width": 340,
        "height": 128,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/eriklueh/microset/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzMEQwRjY5OURFRkNCN0QKUldSOXkrK2RhUThOVTQzRElZRHorbDJ6QVlwdy8zRFFTdWZsckNLRlVnS0RNM1hBc3ZiRFRmUE4K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
